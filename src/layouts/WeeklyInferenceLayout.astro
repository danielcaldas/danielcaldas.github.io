---
import Layout from './Layout.astro'
import {formatDateYMD} from '@utils/format'
import type {PostFrontMatter} from '../type'

interface Props {
    FrontMatter: PostFrontMatter
}
const {FrontMatter} = Astro.props
const title = FrontMatter.title
---

<Layout title={title} navbar={false}>
    <a rel="prefetch" class="panda-link mt-6" href="/the-weekly-inference/">← back</a>
    <style is:inline>
        /* notification */
        .notification p {
            margin-top: 0;
            margin-bottom: 0;
            padding: 0.5rem 1rem;
            font-size: small;
        }

        .notification-warning {
            background-color: #fff3cd;
            border-color: #ffeeba;
            color: #856404;
        }

        .notification-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }

        .notification-success {
            background-color: #d4edda;
            border-color: #c3e6cb;
            color: #155724;
        }

        .notification-info {
            background-color: #d1ecf1;
            border-color: #bee5eb;
            color: #0c5460;
        }

        .dark .notification-warning {
            background-color: #856404;
            border-color: #ffeeba;
            color: #fff3cd;
        }

        .dark .notification-danger {
            background-color: #721c24;
            border-color: #f5c6cb;
            color: #f8d7da;
        }

        .dark .notification-success {
            background-color: #155724;
            border-color: #c3e6cb;
            color: #d4edda;
        }

        .dark .notification-info {
            background-color: #0c5460;
            border-color: #bee5eb;
            color: #d1ecf1;
        }

        .ai-banner {
            border-left: 4px solid currentColor;
            padding: 0.6rem 1rem;
            font-size: 0.8rem;
            font-style: italic;
        }

        .ct {
            position: fixed;
            background: #111;
            color: #e8e8e8;
            border-radius: 8px;
            padding: 10px 13px;
            font-size: 13px;
            max-width: 300px;
            pointer-events: none;
            z-index: 9999;
            box-shadow: 0 4px 20px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.08);
            display: flex;
            align-items: flex-start;
            gap: 9px;
            opacity: 0;
            transition: opacity 0.12s ease;
        }

        .ct.ct-visible {
            opacity: 1;
        }

        .ct-favicon {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
            border-radius: 3px;
            margin-top: 2px;
        }

        .ct-favicon[src=""] { display: none; }

        .ct-title {
            font-weight: 500;
            line-height: 1.35;
            color: #e8e8e8;
        }

        .ct-domain {
            font-size: 11px;
            color: rgba(232,232,232,0.45);
            margin-top: 3px;
        }
    </style>
    <div class="mt-6">
        <h1 class="text-4xl">{title}</h1>
        <div class="flex text-sm opacity-70 mt-2 gap-3 items-center">
            <span>{formatDateYMD(FrontMatter.pubDate)}</span>
        </div>
    </div>
    <div class="notification notification-warning ai-banner mt-6 font-bold">
        This content is 100% AI-generated. No human editing or oversight.
    </div>
    <article class="prose dark:prose-invert prose-stone max-w-none mt-6" id="wi-content">
        <slot />
    </article>
    <script>
        document.querySelectorAll('#wi-content a').forEach((a) => {
            if (a.getAttribute('href')?.startsWith('#')) return
            a.setAttribute('target', '_blank')
            a.setAttribute('rel', 'noopener noreferrer')
        })

        if (window.matchMedia('(pointer: fine)').matches) {
            const CITATION_RE = /^\[\d+\]$/

            // Build href → {title, domain} from cited-source anchors (non-[N] text)
            const titleMap = new Map()
            document.querySelectorAll('#wi-content a[href^="http"]').forEach((a) => {
                const text = a.textContent.trim()
                if (CITATION_RE.test(text)) return
                const href = a.getAttribute('href')
                if (!titleMap.has(href)) {
                    try {
                        const domain = new URL(href).hostname.replace(/^www\./, '')
                        titleMap.set(href, { title: text, domain })
                    } catch {}
                }
            })

            // Create single shared tooltip element
            const tt = document.createElement('div')
            tt.className = 'ct'
            tt.innerHTML = `<img class="ct-favicon" alt="" /><div><div class="ct-title"></div><div class="ct-domain"></div></div>`
            document.body.appendChild(tt)

            const faviconEl = tt.querySelector('.ct-favicon')
            const titleEl = tt.querySelector('.ct-title')
            const domainEl = tt.querySelector('.ct-domain')

            let showTimer

            function positionAndShow(anchor, data) {
                titleEl.textContent = data.title
                domainEl.textContent = data.domain
                faviconEl.src = `https://www.google.com/s2/favicons?domain=${data.domain}&sz=32`
                faviconEl.onerror = () => { faviconEl.src = '' }

                const rect = anchor.getBoundingClientRect()
                const ttW = 300
                const ttH = 58

                let left = rect.left
                let top = rect.top - ttH - 10

                if (top < 8) top = rect.bottom + 10
                if (left + ttW > window.innerWidth - 8) left = window.innerWidth - ttW - 8
                if (left < 8) left = 8

                tt.style.left = `${left}px`
                tt.style.top = `${top}px`
                tt.classList.add('ct-visible')
            }

            document.querySelectorAll('#wi-content a[href^="http"]').forEach((a) => {
                const data = titleMap.get(a.getAttribute('href'))
                if (!data) return

                a.addEventListener('mouseenter', () => {
                    showTimer = setTimeout(() => positionAndShow(a, data), 250)
                })
                a.addEventListener('mouseleave', () => {
                    clearTimeout(showTimer)
                    tt.classList.remove('ct-visible')
                })
            })
        }
    </script>
    {
        FrontMatter.lastModified && FrontMatter.pubDate !== FrontMatter.lastModified && (
            <div class="mt-9 flex text-sm font-italic opacity-80">
                <span class="ml-auto">Last modified on {formatDateYMD(FrontMatter.lastModified)}</span>
            </div>
        )
    }
</Layout>
